{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "primitives": {
      "type": "object",
      "patternProperties": {
        "^num-[0-9_]+$": {
          "type": "object",
          "properties": {
            "value": { "type": ["number", "integer"] }
          },
          "required": ["value"],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["primitives"],
  "additionalProperties": false
}
