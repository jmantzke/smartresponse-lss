{
  "screens": {
    "columns": {
      "xs": { "$type": "number", "$value": "{primitives.size.1}" },
      "sm": { "$type": "number", "$value": "{primitives.size.4}" },
      "md": { "$type": "number", "$value": "{primitives.size.8}" },
      "lg": { "$type": "number", "$value": "{primitives.size.12}" },
      "xl": { "$type": "number", "$value": "{primitives.size.12}" }
    },

    "margin": {
      "xs": { "$type": "number", "$value": "{primitives.size.16}" },
      "sm": { "$type": "number", "$value": "{primitives.size.24}" },
      "md": { "$type": "number", "$value": "{primitives.size.32}" },
      "lg": {
        "$type": "string",
        "$value": "clamp(32px, 5vw, 48px)"
      },
      "xl": {
        "$type": "string",
        "$value": "clamp(48px, 6vw, 64px)"
      }
    },

    "gutter": {
